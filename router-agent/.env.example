# ============ Router Agent 配置 ============

# LLM 配置（MiniMax M2.7，用于意图分类和结果融合）
# 优先使用项目根目录 .env 中的 CHAT_API_KEY
CHAT_API_KEY=your_minimax_api_key_here
CHAT_API_URL=https://api.minimaxi.com/anthropic
CHAT_MODEL=MiniMax-M2.7

# 子系统 API 地址
SQL_SERVICE_URL=http://localhost:8010
RAG_SERVICE_URL=http://localhost:8090

# 服务配置
ROUTER_PORT=8000
ROUTER_HOST=0.0.0.0
REQUEST_TIMEOUT=60
