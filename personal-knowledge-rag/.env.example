# ============ LLM 配置 ============
# MiniMax API（Anthropic 兼容接口）
MINIMAX_API_KEY=your_minimax_api_key_here
# MiniMax GroupId（可选）
MINIMAX_GROUP_ID=
# LLM 模型名称
LLM_MODEL=MiniMax-M2.7
# MiniMax API 地址（Anthropic 兼容）
BASE_URL=https://api.minimaxi.com/anthropic

# ============ Embedding 配置 ============
# SiliconFlow API
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
# Embedding 模型
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# SiliconFlow API 地址
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ============ 知识库配置 ============
# 视频精炼内容目录
VIDEO_KNOWLEDGE_DIR=./video_knowledge
# ChromaDB 本地持久化目录
CHROMA_PERSIST_DIR=./chroma_db

# ============ ChromaDB 远程配置（可选）============
# 如果配置了 CHROMA_HOST，video_knowledge collection 将使用远程 ChromaDB 容器
# 不配置则使用本地持久化（开发模式）
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# ============ 分块配置 ============
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
