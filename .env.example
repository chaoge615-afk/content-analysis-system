# =============================================================================
# 智能内容分析系统 - 统一 API 配置
# =============================================================================
# 所有子项目共享此配置文件，按功能分为 Embedding 和 Chat 两类
# 使用方法：各子项目通过 python-dotenv 加载此文件
# =============================================================================

# =============================================================================
# EMBEDDING API 配置
# =============================================================================
# 用于：文本向量化、语义检索、知识库构建
# 提供商：SiliconFlow（硅基流动）
# 支持项目：personal-knowledge-rag, bilibili-monitor, relationship-analysis

EMBEDDING_PROVIDER=siliconflow
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Docker Compose 兼容变量（映射到 EMBEDDING_*）
SILICONFLOW_API_KEY=${EMBEDDING_API_KEY}
SILICONFLOW_BASE_URL=${EMBEDDING_BASE_URL}

# 备选 Embedding 模型（relationship-analysis 使用）
# EMBEDDING_MODEL_ALT=Qwen/Qwen3-VL-Embedding-8B

# =============================================================================
# CHAT API 配置
# =============================================================================
# 用于：内容精炼、智能问答、意图分类、SQL 生成
# 提供商：MiniMax（Anthropic 兼容接口）、DeepSeek（精炼专用）
# 支持项目：bilibili-monitor, personal-knowledge-rag, text-to-sql

# --- MiniMax M2.7（主 Chat API，Anthropic 兼容） ---
CHAT_PROVIDER=minimax
CHAT_API_KEY=
CHAT_BASE_URL=https://api.minimaxi.com/anthropic
CHAT_MODEL=MiniMax-M2.7

# Docker Compose 兼容变量（映射到 CHAT_*）
MINIMAX_API_KEY=${CHAT_API_KEY}
MINIMAX_BASE_URL=${CHAT_BASE_URL}
MINIMAX_GROUP_ID=
LLM_MODEL=${CHAT_MODEL}

# RAG 服务兼容变量
BASE_URL=${CHAT_BASE_URL}

# --- DeepSeek（精炼专用） ---
REFINE_API_URL=https://api.deepseek.com/v1/chat/completions
REFINE_API_KEY=
REFINE_MODEL=deepseek-v4-flash

# =============================================================================
# RAG 服务配置
# =============================================================================
# 用于：personal-knowledge-rag 文本分块和检索

# LLM 提供者选择：minimax（推荐）或 deepseek
LLM_PROVIDER=minimax
RAG_LLM_MODEL=MiniMax-M2.7

CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# =============================================================================
# bilibili-monitor 配置
# =============================================================================
# 用于：B站视频下载、转写、精炼

# B站 Cookie（用于下载视频）
BILIBILI_COOKIE=

# QQ 通知（可选）
QQ_BOT_URL=
QQ_USER_ID=

# Whisper 转写配置
WHISPER_DEVICE=cpu
WHISPER_MODEL=small
COMPUTE_TYPE=int8

# GPU 转写服务地址（开发机设为 http://gpu-service:8011，NAS 留空自动回退 CPU）
GPU_SERVICE_URL=

# =============================================================================
# 使用说明
# =============================================================================
# 1. 复制此文件为 .env（已存在于根目录）
# 2. 填入各 API_KEY
# 3. 各子项目会自动从此文件加载配置
#
# API 申请地址：
# - SiliconFlow: https://siliconflow.cn/
# - MiniMax: https://www.minimaxi.com/
#
# 项目配置映射：
# - bilibili-monitor: EMBEDDING_*, CHAT_*, REFINE_*, BILIBILI_COOKIE, QQ_*, WHISPER_*
# - personal-knowledge-rag: EMBEDDING_*, CHAT_* (via MINIMAX_API_KEY 兼容), CHUNK_*
# - text-to-sql: CHAT_* (via MINIMAX_API_KEY 兼容)
# - relationship-analysis: EMBEDDING_*
# - router-agent: CHAT_* (via MINIMAX_API_KEY 兼容)
# - frontend: 无需 API 配置
# =============================================================================
